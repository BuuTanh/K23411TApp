<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4FF">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#3F51B5"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 Kết Quả Tìm Kiếm"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/txtQueryHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Từ khóa: --"
            android:textColor="#C5CAE9"
            android:textSize="13sp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Best match card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✅ Ngành phù hợp nhất"
                        android:textColor="#1B5E20"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/txtBestMatch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#1565C0"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/txtBestScore"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Điểm tương đồng (Cosine): --"
                        android:textColor="#555555"
                        android:textSize="13sp"
                        android:layout_marginBottom="12dp"/>

                    <!-- Loading indicator -->
                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="visible"/>

                    <TextView
                        android:id="@+id/txtLoadingMsg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Đang tải dữ liệu từ MYUEL..."
                        android:textColor="#9E9E9E"
                        android:gravity="center"
                        android:textSize="13sp"/>

                    <!-- Result content from web -->
                    <TextView
                        android:id="@+id/txtResultContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#333333"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:visibility="gone"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- All scores card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📈 Điểm tương đồng tất cả ngành"
                        android:textColor="#3F51B5"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:id="@+id/txtScore1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🛒 Thương mại điện tử: --"
                        android:textColor="#1B5E20"
                        android:textSize="14sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/txtScore2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💻 Hệ thống thông tin quản lý: --"
                        android:textColor="#0D47A1"
                        android:textSize="14sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/txtScore3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🤖 Kinh doanh số và TTNT: --"
                        android:textColor="#4A148C"
                        android:textSize="14sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="← Tìm kiếm lại"
                android:textColor="#FFFFFF"
                android:backgroundTint="#3F51B5"
                android:textStyle="bold"
                android:stateListAnimator="@null"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
