<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FF">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#3F51B5"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎓 Tìm Kiếm Ngành Học"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UEL – Cosine Similarity Vector Search"
            android:textColor="#C5CAE9"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

        <!-- Search bar inside header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:background="#FFFFFF"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">

            <EditText
                android:id="@+id/edtQuery"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Nhập từ khóa... VD: AI, marketing, luật"
                android:textSize="14sp"
                android:paddingHorizontal="12dp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"
                android:textColor="#1A1A1A"
                android:textColorHint="#BDBDBD" />

            <ImageButton
                android:id="@+id/btnVoice"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="#3F51B5"
                android:src="@android:drawable/ic_btn_speak_now"
                android:contentDescription="Voice"
                android:scaleType="centerInside"
                android:tint="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>

    <!-- Suggestion label -->
    <TextView
        android:id="@+id/txtSuggestionLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gợi ý ngành phù hợp nhất"
        android:textColor="#757575"
        android:textSize="11sp"
        android:letterSpacing="0.05"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp"
        android:visibility="gone" />

    <!-- Live suggestion list -->
    <ListView
        android:id="@+id/listSuggestions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#E8EAF6"
        android:dividerHeight="1dp"
        android:background="#FFFFFF"
        android:visibility="gone" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍"
            android:textSize="60sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nhập từ khóa để tìm ngành"
            android:textColor="#757575"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gợi ý sẽ xuất hiện ngay khi bạn gõ"
            android:textColor="#BDBDBD"
            android:textSize="13sp"
            android:layout_marginTop="6dp"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:gravity="center">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="kế toán" android:textColor="#3F51B5" android:textSize="12sp"
                android:background="#E8EAF6" android:paddingHorizontal="10dp" android:paddingVertical="5dp"
                android:layout_marginEnd="6dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="AI" android:textColor="#3F51B5" android:textSize="12sp"
                android:background="#E8EAF6" android:paddingHorizontal="10dp" android:paddingVertical="5dp"
                android:layout_marginEnd="6dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="luật" android:textColor="#3F51B5" android:textSize="12sp"
                android:background="#E8EAF6" android:paddingHorizontal="10dp" android:paddingVertical="5dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Voice status bar -->
    <TextView
        android:id="@+id/txtVoiceStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FFFFFF"
        android:background="#5C6BC0"
        android:textSize="13sp"
        android:gravity="center"
        android:paddingVertical="10dp"
        android:visibility="gone" />

</LinearLayout>
