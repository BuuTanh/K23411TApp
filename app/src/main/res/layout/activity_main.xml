<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2FA"
    tools:context=".MainActivity">

    <!-- Welcome strip — giữ đúng vị trí cũ -->
    <TextView
        android:id="@+id/txtWelcome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Xin chào!"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:background="@drawable/bg_welcome_strip"
        android:paddingHorizontal="20dp"
        android:paddingVertical="18dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="20dp">

            <Button
                android:id="@+id/button5"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:onClick="say_hello"
                android:text="Click me!"
                android:background="@drawable/bg_btn_outline"
                android:textColor="#3F51B5"
                android:textStyle="bold"
                android:textSize="14sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/button6"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:onClick="exit_app"
                android:text="Close"
                android:background="@drawable/bg_danger_btn"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:stateListAnimator="@null" />

            <TextView
                android:id="@+id/textView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hey! K23411T"
                android:textColor="#9E9E9E"
                android:textSize="12sp"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/textView2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/str_university"
                android:textColor="#3F51B5"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="14dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DADCE0"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:onClick="show_my_major"
                android:text="@string/str_your_major"
                android:background="@drawable/bg_primary_btn"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/button2"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:onClick="openCalculatorApp"
                android:text="@string/str_open_calculator_app"
                android:background="@drawable/bg_primary_btn"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/button3"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:onClick="openOrderManagement"
                android:text="@string/str_order_management"
                android:background="@drawable/bg_primary_btn"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/button4"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:onClick="openCategoryManagement"
                android:text="@string/str_category_management"
                android:background="@drawable/bg_primary_btn"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/button9"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:onClick="openMyContactManagement"
                android:text="@string/str_mycontact_management"
                android:background="@drawable/bg_primary_btn"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:stateListAnimator="@null" />

            <Button
                android:onClick="openSMSSpywareActivity"
                android:id="@+id/button10"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/str_sms_spyware" />

            <Button
                android:onClick="openMultiThreadActivity"
                android:id="@+id/btnMultiThreadDemo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/str_multi_thread_demo" />

            <Button
                android:onClick="openMultiThreadObjectActivity"
                android:id="@+id/button12"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/str_multithreading_object_demo" />

            <Button
                android:id="@+id/btnMyUEL"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:onClick="openMyUELSearch"
                android:text="🎓 Tìm Kiếm Ngành Học (MYUEL)"
                android:background="@drawable/bg_primary_btn"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnWeather"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:onClick="openWeatherActivity"
                android:text="🌤 Dự Báo Thời Tiết"
                android:background="@drawable/bg_primary_btn"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:stateListAnimator="@null" />

            <Button
                android:onClick="openFontAndMusicActivity"
                android:id="@+id/button13"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/str_font_music" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
